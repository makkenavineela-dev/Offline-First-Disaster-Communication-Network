# Use Node 22 LTS Alpine — matches the development environment exactly.
# Node 18 would work but produces npm version warnings with the lock file
# generated by npm 10.x (which ships with Node 22).
FROM node:22-alpine
 
# Set working directory
WORKDIR /usr/src/app
 
# Copy package files first (layer-cache friendly)
COPY package*.json ./
 
# Install only production dependencies using the exact lock file
RUN npm ci --omit=dev
 
# Copy application source (after install so source changes don't bust npm cache)
COPY . .
 
# Exclude local dev files and secrets from the image
RUN rm -f .env
 
# Expose standard port
EXPOSE 5000
 
# Run as non-root user for security
USER node

# Start the server
CMD [ "node", "server.js" ]
